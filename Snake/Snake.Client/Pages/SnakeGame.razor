@page "/snake"

@rendermode InteractiveServer

@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using CS3500.Networking
@using Microsoft.Extensions.Logging.Abstractions
@using System.Text.Json
@using CS3500.Snake.Models

@inject IJSRuntime JsRuntime;
@inject ILogger<Program> Logger;

@namespace CS3500.Snake.Client.Pages.SnakeGame 

<PageTitle>Chat Client</PageTitle>

<script src="_content/Blazor.Extensions.Canvas/blazor.extensions.canvas.min.js"></script>

<h1>Chat Client</h1>

<div id="ConnectionInputs">
    <div class="input-row">
        <label for="name"> Your Name: </label>
        <input id="name" disabled="@connection.IsConnected" type="text" @bind="playerName" />
    </div>

    <div class="input-row">
        <label for="url"> Server Address: </label>
        <input id="url" disabled="@connection.IsConnected" type="text" @bind="serverHost" />
        <label for="url"> Port: </label>
        <input id="port" disabled="@connection.IsConnected" type="number" @bind="serverPort" class="port" />
        @if ( connection.IsConnected )
        {
            <button class="btn btn-primary" @onclick="DisconnectFromServer">Disconnect</button>
        }
        else
        {
            <button class="btn btn-primary" @onclick="Connect">Connect</button>
        }
        <div class="@connectionSpinnerClass"></div>
    </div>
    @if(!string.IsNullOrEmpty( serverStatusMessage ) )
    {
        <p> @serverStatusMessage</p>
    }
    <div id="myCanvas">
        <BECanvas Width="CanvasWidth" Height="CanvasHeight" @ref="canvasReference"/>
    </div>
</div>

@code
{
    // Drawing/Canvas variables here.
    private BECanvasComponent canvasReference;
    private Canvas2DContext context = null!;
    private IJSObjectReference _jsModule = null!;

    // Connection and user inputs
    private string serverHost = "localhost";
    private int serverPort = 11000;
    private string playerName = "Your Name Here";

    // UI state
    private string serverStatusMessage = string.Empty;
    private string connectionSpinnerClass = string.Empty;

    /// <summary>
    ///     The NetworkConnection object representing a connection with the server.
    /// </summary>
    private NetworkConnection connection = null!;

    /// <summary>
    /// Serialized command to move up.
    /// </summary>
    private readonly string UpCommand = JsonSerializer.Serialize(new ControlCommand("up"));
    private readonly string DownCommand = JsonSerializer.Serialize(new ControlCommand("down"));
    private readonly string RightCommand = JsonSerializer.Serialize(new ControlCommand("right"));
    private readonly string LeftCommand = JsonSerializer.Serialize(new ControlCommand("left"));

    // Canvas dimensions
    private readonly int CanvasWidth = 1000;
    private readonly int CanvasHeight = 1000;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        connection = new NetworkConnection( Logger );
        Logger.LogInformation("SnakeGame component initializing network connection object.");
        // TODO: Consider handling initialization failures (connection object creation) gracefully.
    }

    protected override async Task OnAfterRenderAsync( bool firstRender )
    {
        if ( firstRender )
        {
            Logger.LogInformation("First render: importing JS module and creating canvas context.");
            // TODO: Consider wrapping JS import and canvas creation in try/catch and surface user-friendly errors.
            _jsModule = await JsRuntime.InvokeAsync<IJSObjectReference>( "import", "./Pages/SnakeGame.razor.js" );
            context = await canvasReference.CreateCanvas2DAsync();
            await _jsModule.InvokeVoidAsync( "initJS", DotNetObjectReference.Create( this ) );
            Logger.LogInformation("Initialized JS interop and canvas context.");
        }
    }

    /// <summary>
    /// Handles keyboard input for WASD and Arrow keys, sending movement command to the server.
    /// Invoked from JS with the pressed key string.
    /// </summary>
    [JSInvokable]
    public void HandleKeyPress(string key)
    {
        if (string.IsNullOrEmpty(key))
        {
            return;
        }

        // TODO: Consider try/catch to handle send failures gracefully.
        var k = key.ToLowerInvariant();
        switch (k)
        {
            case "arrowup":
            case "w":
                connection.SendLine(UpCommand);
                break;
            case "arrowright":
            case "d":
                connection.SendLine(RightCommand);
                break;
            case "arrowdown":
            case "s":
                connection.SendLine(DownCommand);
                break;
            case "arrowleft":
            case "a":
                connection.SendLine(LeftCommand);
                break;
            default:
                break;
        }
    }

    /// <summary>
    /// Draw a single frame to the canvas based on the current World state.
    /// Invoked continuously by JavaScript with a timestamp.
    /// </summary>
    [JSInvokable]
    public async Task Draw(double _)
    {
        try
        {
            frameCount++;
            await context.BeginBatchAsync();

            // Clip to canvas, center origin, and draw background
            await context.BeginPathAsync();
            await context.RectAsync( 0, 0, CanvasWidth, CanvasHeight );
            await context.ClipAsync();
            await context.SaveAsync();

            var halfW = CanvasWidth / 2;
            var halfH = CanvasHeight / 2;
            await context.TranslateAsync( halfW, halfH );

            IEnumerable<Snake> snakes = world.Snakes.Values;
            Point2D head = world.Snakes[playerId].Head;
            IEnumerable<PowerUp> powerUps = world.PowerUps.Values;
            IEnumerable<Wall> walls = world.Walls.Values;
            await context.TranslateAsync( -head.X, -head.Y );


            await context.SetFillStyleAsync( "darkblue" );
            await context.FillRectAsync( -world.Size / 2, -world.Size / 2, world.Size, world.Size);

            // Draw each of the element types:

            // Snakes
            await context.Draw(snakes);
            // Power Ups
            await context.Draw(powerUps);
            // Walls
            await context.Draw(walls);


            // HUD
            await context.SetFontAsync( "30px Arial" );
            await context.SetFillStyleAsync( "white" );
            await context.FillTextAsync( $"FPS: {AvgFps:F1}", 400, 30 );

            await context.RestoreAsync();
            await context.EndBatchAsync();
        }
        catch ( Exception e )
        {
            // Error-level logging permitted in draw loop
            Logger.LogError(e, "Error drawing");
            // TODO: Consider surfacing a non-intrusive UI notification and stopping animation on repeated failures.
        }
    }
}
